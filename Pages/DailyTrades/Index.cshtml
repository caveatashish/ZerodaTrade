@page
@model ZerodaTrade.Pages.DailyTrades.IndexModel
@{
    ViewData["Title"] = "Daily Trades";
}

<div class="container mt-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>@ViewData["Title"]</h2>
        <a class="btn btn-primary" asp-page="/DailyTrades/Create">Add New Trade</a>
    </div>

    @if (Model.DailyTrades != null && Model.DailyTrades.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-bordered">
                <thead class="table-light">
                    <tr>
                        <th>Trade ID</th>
                        <th>Fill Time</th>
                        <th>Type</th>
                        <th>Instrument</th>
                        <th>CNC</th>
                        <th>Qty.</th>
                        <th>Avg. Price</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in Model.DailyTrades)
                    {
                        <tr>
                            <td>@t.TradeId</td>
                            <td>@t.FillTime.ToString("M/d/yyyy H:mm")</td>
                            <td>@t.Type</td>
                            <td>@t.Instrument</td>
                            <td>@(t.CNC.HasValue && t.CNC.Value ? "Yes" : "No")</td>
                            <td>@t.Qty</td>
                            <td>@t.AvgPrice.ToString("F2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">No trades found. Click "Add New Trade" to create one.</div>
    }
</div>

@section Scripts {
    <!-- page-specific scripts if needed -->
}
