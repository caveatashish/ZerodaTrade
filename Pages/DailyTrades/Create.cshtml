@page
@model ZerodaTrade.Pages.DailyTrades.CreateModel
@{
    ViewData["Title"] = "Add New Daily Trade";
}

<div class="container mt-3">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">@ViewData["Title"]</h4>
                </div>
                <div class="card-body">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="mb-3">
                            <label asp-for="DailyTrade.TradeId" class="form-label"></label>
                            <input asp-for="DailyTrade.TradeId" class="form-control" type="number" required />
                            <small class="form-text text-muted">Provide unique Trade ID</small>
                            <span asp-validation-for="DailyTrade.TradeId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="DailyTrade.FillTime" class="form-label"></label>
                            <input asp-for="DailyTrade.FillTime" class="form-control" type="datetime-local" />
                            <span asp-validation-for="DailyTrade.FillTime" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="DailyTrade.Type" class="form-label"></label>
                            <select asp-for="DailyTrade.Type" class="form-select" required>
                                <option value="">-- Select Type --</option>
                                <option value="buy">Buy</option>
                                <option value="sell">Sell</option>
                            </select>
                            <span asp-validation-for="DailyTrade.Type" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="DailyTrade.Instrument" class="form-label"></label>
                            <input asp-for="DailyTrade.Instrument" class="form-control" placeholder="Instrument name (e.g., MARUTI)" required />
                            <span asp-validation-for="DailyTrade.Instrument" class="text-danger"></span>
                        </div>

                        <div class="form-check mb-3">
                            <input asp-for="DailyTrade.CNC" class="form-check-input" type="checkbox" />
                            <label asp-for="DailyTrade.CNC" class="form-check-label">CNC</label>
                            <span asp-validation-for="DailyTrade.CNC" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="DailyTrade.Qty" class="form-label"></label>
                            <input asp-for="DailyTrade.Qty" class="form-control" type="number" min="1" required />
                            <span asp-validation-for="DailyTrade.Qty" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="DailyTrade.AvgPrice" class="form-label"></label>
                            <input asp-for="DailyTrade.AvgPrice" class="form-control" type="number" step="0.01" required />
                            <span asp-validation-for="DailyTrade.AvgPrice" class="text-danger"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success">Create</button>
                            <a asp-page="/DailyTrades/Index" class="btn btn-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
