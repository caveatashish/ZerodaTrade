@page
@model ZerodaTrade.Pages.DailyTradeV2.UploadModel
@{
    ViewData["Title"] = "Daily Trades - CSV Upload (v2)";
}

<div class="container mt-3">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-secondary text-white">
                    <h4 class="mb-0">@ViewData["Title"]</h4>
                </div>
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(Model.UploadResult))
                    {
                        <div class="alert alert-success">@Model.UploadResult</div>
                    }
                    @if (!string.IsNullOrEmpty(Model.UploadErrors))
                    {
                        <div class="alert alert-warning"><pre>@Model.UploadErrors</pre></div>
                    }

                    <form method="post" enctype="multipart/form-data">
                        <div class="mb-3">
                            <label class="form-label">CSV File</label>
                            <input asp-for="File" type="file" accept=".csv" class="form-control" />
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Upload</button>
                            <a asp-page="/DailyTrades/Index" class="btn btn-secondary">Back to Trades</a>
                        </div>
                    </form>

                    <hr />
                    <p class="text-muted small">Expected CSV columns (in order): <strong>Trade ID, Fill time, Type, Instrument, CNC, Qty., Avg. Price</strong></p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
