@model ZerodaTrade.Models.Script
@{
    var groups = ViewBag.Groups as List<ZerodaTrade.Models.Group>;
}

<div class="modal-header"><h5>Edit Script</h5></div>
<div class="modal-body">
    <form id="editForm">
        <input type="hidden" id="editId" name="Id" value="@Model.Id" />
        <div class="mb-3">
            <label>Name</label>
            <input type="text" id="editName" name="Name" class="form-control" value="@Model.Name" />
        </div>
        <div class="mb-3">
            <label>Status</label>
            <input type="checkbox" id="editStatus" name="Status" @(Model.Status ? "checked" : "") />
        </div>
        <div class="mb-3">
            <label>Group</label>
            <select id="editGroupId" name="GroupId" class="form-select">
                @foreach (var group in groups)
                {
                    if (group.Id == Model.GroupId)
                    {
                        <option value="@group.Id" selected="selected">@group.Name</option>
                    }
                    else
                    {
                        <option value="@group.Id">@group.Name</option>
                    }
                }
            </select>
        </div>
    </form>
</div>
<div class="modal-footer">
    <button type="button" class="btn btn-success" onclick="submitEditForm()">Save</button>
</div>
