@model IEnumerable<Script>
@{
    var groups = ViewBag.Groups as List<Group>;
}

<h2>Scripts</h2>
<button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createModal">Add Script</button>

<table class="table table-striped" id="scriptTable">
    <thead>
        <tr>
            <th>Name</th>
            <th>Status</th>
            <th>Group</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var script in Model)
        {
            <tr id="row-@script.Id">
                <td>@script.Name</td>
                <td>@(script.Status ? "Active" : "Inactive")</td>
                <td>@script.Group?.Name</td>
                <td>
                    <button class="btn btn-sm btn-warning"
                            onclick="openEditModal(@script.Id)">
                        Edit
                    </button>
                    <button class="btn btn-sm btn-danger" onclick="openDeleteModal(@script.Id)">Delete</button>
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- Create Modal -->
<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="createForm">
                <div class="modal-header"><h5>Add Script</h5></div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label>Name</label>
                        <input type="text" id="createName" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label>Status</label>
                        <input type="checkbox" id="createStatus" />
                    </div>
                    <div class="mb-3">
                        <label>Group</label>
                        <select id="createGroupId" class="form-select">
                            @foreach (var group in groups)
                            {
                                <option value="@group.Id">@group.Name</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-primary" onclick="createScript()">Create</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Modal (content loaded via AJAX) -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content" id="editModalContent">
            <!-- partial loaded here -->
        </div>
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="deleteForm">
                <div class="modal-header"><h5>Confirm Delete</h5></div>
                <div class="modal-body">
                    <input type="hidden" id="deleteId" />
                    Are you sure you want to delete this script?
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-danger" onclick="deleteScript()">Delete</button>
                </div>
            </form>
        </div>
    </div>
</div>


            <script>

                    function createScript() {
        var script = {
            Name: $("#createName").val(),
            Status: $("#createStatus").is(":checked"),
            GroupId: $("#createGroupId").val()
        };

        $.ajax({
            url: '/Script/Create',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(script),
            success: function (res) {
                if (res.success) {
                    location.reload(); // or dynamically append row
                } else {
                    alert(res.message);
                }
            }
        });
    }

    function openEditModal(id, name, status, groupId) {
        // load partial edit form into modal
        $.get('/Script/Edit/' + id, function (html) {
            $('#editModalContent').html(html);
            $('#editModal').modal('show');
        });
    }
    function submitEditForm() {
        var form = $('#editForm');
        var script = {
            Id: $('#editId').val(),
            Name: $('#editName').val(),
            Status: $('#editStatus').is(':checked'),
            GroupId: $('#editGroupId').val()
        };

        $.ajax({
            url: '/Script/Edit',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(script),
            success: function (res) {
                if (res.success) {
                    // refresh only the table body via AJAX
                    refreshScripts();
                } else {
                    alert(res.message);
                }
            }
        });
    }

    function refreshScripts() {
        $.get('/Script/List', function (html) {
            $('#scriptTable tbody').html(html);
            $('#editModal').modal('hide');
        });
    }

    function openDeleteModal(id) {
        $("#deleteId").val(id);
        $("#deleteModal").modal("show");
    }

    function deleteScript() {
        var id = $("#deleteId").val();

        $.ajax({
            url: '/Script/Delete',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(id),
            success: function (res) {
                if (res.success) {
                    $("#row-" + id).remove();
                    $("#deleteModal").modal("hide");
                } else {
                    alert(res.message);
                }
            }
        });
    }


            </script>