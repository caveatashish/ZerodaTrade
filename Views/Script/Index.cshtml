@model IEnumerable<Script>
@{
    var groups = ViewBag.Groups as List<Group>;
}

<div class="d-flex align-items-center mb-3">
    <h2 class="me-3">Scripts</h2>
    <div class="me-3" style="min-width:300px; max-width:50%">
        <input id="scriptSearch" class="form-control" placeholder="Search scripts by name..." />
    </div>
    <button class="btn btn-primary ms-auto" data-bs-toggle="modal" data-bs-target="#createModal">Add Script</button>
</div>

<table class="table table-striped" id="scriptTable">
    <thead>
        <tr>
            <th>Name</th>
            <th>Status</th>
            <th>Group</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var script in Model)
        {
            <tr id="row-@script.Id">
                <td>@script.Name</td>
                <td>@(script.Status ? "Active" : "Inactive")</td>
                <td>@script.Group?.Name</td>
                <td>
                    <button class="btn btn-sm btn-warning"
                            onclick="openEditModal(@script.Id)">
                        Edit
                    </button>
                    <button class="btn btn-sm btn-danger" onclick="openDeleteModal(@script.Id)">Delete</button>
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- Create Modal -->
<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="createForm">
                <div class="modal-header"><h5>Add Script</h5></div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label>Name</label>
                        <input type="text" id="createName" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label>Status</label>
                        <input type="checkbox" id="createStatus" />
                    </div>
                    <div class="mb-3">
                        <label>Group</label>
                        <select id="createGroupId" class="form-select">
                            @foreach (var group in groups)
                            {
                                <option value="@group.Id">@group.Name</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-primary" onclick="createScript()">Create</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Modal (content loaded via AJAX) -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content" id="editModalContent">
            <!-- partial loaded here -->
        </div>
    </div>
</div>

<!-- Trade Modal -->
<div class="modal fade" id="tradeModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content" id="tradeModalContent">
            <!-- loaded via AJAX: summary + detail placeholder -->
        </div>
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="deleteForm">
                <div class="modal-header"><h5>Confirm Delete</h5></div>
                <div class="modal-body">
                    <input type="hidden" id="deleteId" />
                    Are you sure you want to delete this script?
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-danger" onclick="deleteScript()">Delete</button>
                </div>
            </form>
        </div>
    </div>
</div>


            <script>

                    function createScript() {
        var script = {
            Name: $("#createName").val(),
            Status: $("#createStatus").is(":checked"),
            GroupId: $("#createGroupId").val()
        };

        $.ajax({
            url: '/Script/Create',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(script),
            success: function (res) {
                if (res.success) {
                    location.reload(); // or dynamically append row
                } else {
                    alert(res.message);
                }
            }
        });
    }

    function openEditModal(id, name, status, groupId) {
        // load partial edit form into modal
        $.get('/Script/Edit/' + id, function (html) {
            $('#editModalContent').html(html);
            $('#editModal').modal('show');
        });
    }
    function submitEditForm() {
        var script = {
            Id: $('#editId').val(),
            Name: $('#editName').val(),
            Status: $('#editStatus').is(':checked'),
            GroupId: $('#editGroupId').val()
        };

        $.ajax({
            url: '/Script/Edit',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(script),
            success: function (res) {
                if (res.success) {
                    // fetch updated single row HTML and replace existing row
                    $.get('/Script/Row/' + script.Id, function (rowHtml) {
                        $('#row-' + script.Id).replaceWith(rowHtml);
                        $('#editModal').modal('hide');
                    });
                } else {
                    alert(res.message);
                }
            }
        });
    }

    function openDeleteModal(id) {
        $("#deleteId").val(id);
        $("#deleteModal").modal("show");
    }

    function deleteScript() {
        var id = $("#deleteId").val();

        $.ajax({
            url: '/Script/Delete',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(id),
            success: function (res) {
                if (res.success) {
                    $("#row-" + id).remove();
                    $("#deleteModal").modal("hide");
                } else {
                    alert(res.message);
                }
            }
        });
    }

    // search debounce
    (function(){
        var _searchTimer = null;
        $(document).ready(function(){
            $('#scriptSearch').on('input', function(){
                var q = $(this).val();
                clearTimeout(_searchTimer);
                _searchTimer = setTimeout(function(){
                    $.get('/Script/List', { q: q }, function(html){
                        $('#scriptTable tbody').html(html);
                    });
                }, 300);
            });
        });
    })();

    // open trades for a script in modal
    window.openScriptTrades = function(instrument) {
        if (!instrument) return;
        $.get('/Script/Trades', { instrument: instrument }, function(html) {
            // load summary and a placeholder for day details into modal
            var content = '<div class="p-3">' + html + '<div id="tradeDayDetail" class="mt-3"></div></div>';
            $('#tradeModalContent').html(content);
            var m = new bootstrap.Modal(document.getElementById('tradeModal'));
            m.show();
        });
    };

    // delegated handler inside modal: when clicking summary row load day trades
    $(document).on('click', '#tradeModal .summary-row', function(){
        var instrument = $(this).data('instrument');
        var date = $(this).data('date');
        if (!instrument || !date) return;
        $.get('/Script/GetDayTrades', { instrument: instrument, date: date }, function(html){
            $('#tradeDayDetail').html(html);
        });
    });

    // open edit trade modal
    window.openEditTrade = function(id) {
        if (!id) return;
        $.get('/Script/EditTrade?id=' + id, function(html) {
            // show in the same trade modal as a nested modal content
            var $modal = $('#tradeModalContent');
            $modal.find('#tradeDayDetail').html(html);
        });
    };

    // submit trade edit
    window.submitTradeEdit = function() {
        var trade = {
            Id: $('#tradeId').val(),
            Type: $('#tradeType').val(),
            Qty: parseInt($('#tradeQty').val() || '0'),
            AvgPrice: parseFloat($('#tradeAvgPrice').val() || '0'),
            CNC: $('#tradeCNC').is(':checked')
        };
        $.ajax({
            url: '/Script/EditTrade',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(trade),
            success: function(res) {
                if (res.success) {
                    // refresh day trades if instrument/date present
                    var instrument = $('#tradeInstrument').val();
                    var date = $('#tradeDate').val();
                    if (instrument && date) {
                        $.get('/Script/GetDayTrades', { instrument: instrument, date: date }, function(html){
                            $('#tradeDayDetail').html(html);
                        });
                    }
                } else {
                    alert(res.message || 'Failed to save trade');
                }
            }
        });
    };

            </script>
