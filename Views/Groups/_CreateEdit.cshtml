@model ZerodaTrade.Models.Group


<form asp-action="@ViewContext.RouteData.Values["action"]" method="post" class="ajax-form">
    <div class="modal-header">
        <h5 class="modal-title">@((Model.Id == 0) ? "Create Group" : "Edit Group")</h5>
        <button type="button" class="close" data-dismiss="modal">&times;</button>
    </div>
    <div class="modal-body">
        <div class="form-group">
            <label asp-for="Name"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="Description"></label>
            <input asp-for="Description" class="form-control" />
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>
        <div class="form-group form-check">
            <input asp-for="Status" class="form-check-input" />
            <label asp-for="Status" class="form-check-label"></label>
        </div>
    </div>
    <div class="modal-footer">
        <button type="submit" class="btn btn-primary">Save</button>
        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}


