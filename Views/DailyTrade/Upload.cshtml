@{
    ViewData["Title"] = "Upload Daily Trades CSV";
}

<div class="container mt-3">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-secondary text-white">
                    <h4 class="mb-0">@ViewData["Title"]</h4>
                </div>
                <div class="card-body">
                    @if (TempData["UploadResult"] != null)
                    {
                        <div class="alert alert-success">@TempData["UploadResult"]</div>
                    }
                    @if (TempData["UploadErrors"] != null)
                    {
                        <div class="alert alert-warning"><pre>@TempData["UploadErrors"]</pre></div>
                    }

                    <form asp-controller="DailyTrade" asp-action="UploadFile" method="post" enctype="multipart/form-data">
                        <div class="mb-3">
                            <label class="form-label">CSV File</label>
                            <input type="file" name="file" accept=".csv" class="form-control" required />
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Upload</button>
                            <a class="btn btn-secondary" asp-page="/DailyTrades/Index">Back to Trades</a>
                        </div>
                    </form>

                    <hr />
                    <p class="text-muted small">Expected CSV columns (in order): <strong>Trade ID, Fill time, Type, Instrument, CNC, Qty., Avg. Price</strong></p>
                </div>
            </div>
        </div>
    </div>
</div>
