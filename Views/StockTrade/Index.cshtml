@model IEnumerable<ZerodaTrade.Models.Group>

@{
    ViewData["Title"] = "Stock Trades";
}

<div class="d-flex align-items-center mb-3">
    <h2 class="me-4">Stock Trades</h2>
    <div id="groupList" class="d-flex flex-row flex-nowrap overflow-auto border rounded p-2 ms-auto" style="min-width:300px; max-width:70%">
        @foreach (var g in Model)
        {
            <div class="form-check me-3">
                <input class="form-check-input group-checkbox" type="checkbox" value="@g.Id" id="group-@g.Id" />
                <label class="form-check-label" for="group-@g.Id">@g.Name</label>
            </div>


        }
    </div>
</div>

<div class="row">
    <div class="col-md-2">
        <h5>Stocks</h5>
        <div id="stockList" class="border rounded p-2" style="overflow-x:hidden;">
            <!-- loaded via AJAX -->
        </div>
    </div>
    <div class="col-md-6">
        <div style="display:flex; justify-content:space-between; align-items:center;">
            <div style="display:flex; align-items:center;">
                <h5 class="mb-0">Trades</h5>
                <div id="currentInstrumentContainer" class="ms-3">
                    <a href="#" id="currentInstrumentLink" class="btn btn-sm btn-outline-primary" style="display:none;">&nbsp;</a>
                </div>
            </div>

        </div>
        <div id="tradeTable">
            <!-- loaded via AJAX -->
        </div>
    </div>
    <div class="col-md-3 d-flex flex-column" style="height:100%;">
        <!-- Upper block: Stock Stats -->
        <div class="mb-3 flex-grow-1 border rounded p-2">
            <h5>Stock Stats</h5>
            <div id="stockStats">
                <!-- summary stats will load here -->
            </div>
        </div>

        <div id="middleBody" class="mb-3 border rounded p-2">
            <h5 class="mb-1">Intraday Price Diff</h5>
            <div id="dayDiff" class="text-muted">Select a day from the trades table to view buy/sell diffs.</div>
        </div>

        <!-- Lower block: Day Trade -->
        <div class="flex-grow-1 border rounded p-2">
            <h5>Day Trade</h5>
            <div id="SpecififDayTrade">
                <!-- detailed trades for selected day will load here -->
            </div>
        </div>
    </div>

</div>



<script>
    $(function(){
        // ensure only one group checkbox can be selected; load stocks for selected group
        $(document).on('change', '.group-checkbox', function(){
            // uncheck other checkboxes so only one remains checked
            $('.group-checkbox').not(this).prop('checked', false);

            var checked = $('.group-checkbox:checked');
            if(checked.length === 0){
                // no group selected: clear stock list and show recent trades for last 5 days
                $('#stockList').html('');
                $('#SpecififDayTrade').html('');
                $('#currentInstrumentLink').hide();
                $.get('/StockTrade/GetRecentTrades?days=5', function(html){
                    $('#tradeTable').html(html);
                });
                return;
            }
            var groupId = checked.val();
            $.get('/StockTrade/GetStocks?groupId=' + groupId, function(html){
                $('#stockList').html(html);
                $('#stockStats').html('');
                $('#SpecififDayTrade').html('');
                $('#currentInstrumentLink').hide();
            });
            // also show recent trades for the selected group when no stock selected
            $.get('/StockTrade/GetRecentTradesByGroup?groupId=' + groupId + '&days=5', function(html){
                $('#tradeTable').html(html);
            });
        });

        // when clicking on a stock link (delegated)
        $(document).on('click', '.stock-link', function(e){
            e.preventDefault();
            var instrument = $(this).data('instrument');
            // highlight the clicked stock in the list
            $('.stock-link').removeClass('active-stock');
            $(this).addClass('active-stock');
            // update current instrument display and make it clickable
            $('#currentInstrumentLink').text(instrument).attr('href', '/StockTrade/StockReconcile?instrument=' + encodeURIComponent(instrument)).show();
            $.get('/StockTrade/GetTrades?instrument=' + encodeURIComponent(instrument), function(html){
                $('#tradeTable').html(html);
                // clear specific day details when new summary loads
                $('#SpecififDayTrade').html('');
                // load stats for selected stock into the stockStats div
                $.get('/ScriptStats/GetByInstrument?instrument=' + encodeURIComponent(instrument), function(partialHtml){
                    $('#stockStats').html(partialHtml);
                }).fail(function(){
                    $('#stockStats').html('<div class="text-muted">No stats available</div>');
                });
            });
        });

        // when clicking on a summary row load detailed trades for that day
        // and compute intraday diffs for three columns: Same Day, Buy->Sell, Sell->Buy
        $(document).on('click', '#tradeTable .summary-row', function(){
            var instrument = $(this).data('instrument');
            var date = $(this).data('date');
            if(!instrument || !date) return;

            // load detailed trades (server)
            $.get('/StockTrade/GetDayTrades', { instrument: instrument, date: date }, function(html){
                $('#SpecififDayTrade').html(html);
            });

            var $row = $(this);
            var $next = $row.next('tr');

            function parseNum(text){
                if(!text) return null;
                var cleaned = text.replace(/,/g, '').replace(/[^0-9.\-]/g,'').trim();
                if(cleaned === '') return null;
                var v = parseFloat(cleaned);
                return isNaN(v) ? null : v;
            }

            // columns: 0=date,1=buyQty,2=buyAvg,3=buyTotal,4=sellQty,5=sellAvg,6=sellTotal
            var buyAvg_curr = parseNum($row.find('td').eq(2).text());
            var sellAvg_curr = parseNum($row.find('td').eq(5).text());
            var buyAvg_next = $next.length ? parseNum($next.find('td').eq(2).text()) : null;
            var sellAvg_next = $next.length ? parseNum($next.find('td').eq(5).text()) : null;

            // Prepare values for three columns
            var same = { buy: null, sell: null, diff: null, pct: null };
            var bs = { buy: null, sell: null, diff: null, pct: null };
            var sb = { sell: null, buy: null, diff: null, pct: null };

            // Same-day (both buy and sell present in the same row)
            if(buyAvg_curr !== null && sellAvg_curr !== null){
                same.buy = buyAvg_curr;
                same.sell = sellAvg_curr;
                same.diff = same.sell - same.buy;
                same.pct = same.buy !== 0 ? (same.diff / same.buy) * 100 : null;
            }

            // Buy -> Sell (current row buy and next row sell)
            if(buyAvg_curr !== null && sellAvg_next !== null){
                bs.buy = buyAvg_curr;
                bs.sell = sellAvg_next;
                bs.diff = bs.sell - bs.buy;
                bs.pct = bs.buy !== 0 ? (bs.diff / bs.buy) * 100 : null;
            }

            // Sell -> Buy (current row sell and next row buy)
            if(sellAvg_curr !== null && buyAvg_next !== null){
                sb.sell = sellAvg_curr;
                sb.buy = buyAvg_next;
                sb.diff = sb.sell - sb.buy;
                sb.pct = sb.sell !== 0 ? (sb.diff / sb.sell) * 100 : null;
            }

            function fmt(val){ return val === null ? '-' : Number(val).toFixed(2); }
            function fmtt(val){ return val === null ? '-' : (Number(val).toFixed(2) + (val !== null ? '' : '')); }
            function fmtPct(val){ return val === null ? '-' : Number(val).toFixed(2) + '%'; }

            var html = '<div class="border rounded p-2" style="width:100%;">' +
                       '<h6 class="mb-2">Intraday Price Diff</h6>' +
                       '<table class="table table-sm" style="margin-bottom:0;">' +
                       '<thead class="table-light"><tr><th style="width:60px;"></th><th class="text-end">Same Day</th><th class="text-end">Buy-&gt;Sell</th><th class="text-end">Sell-&gt;Buy</th></tr></thead>' +
                       '<tbody>' +
                       '<tr><td class="fw-bold bg-warning">Buy</td>' +
                       '<td class="text-end">' + fmt(same.buy) + '</td>' +
                       '<td class="text-end">' + fmt(bs.buy) + '</td>' +
                       '<td class="text-end">' + fmt(sb.buy) + '</td>' +
                       '</tr>' +
                       '<tr><td class="fw-bold bg-warning">Sell</td>' +
                       '<td class="text-end">' + fmt(same.sell) + '</td>' +
                       '<td class="text-end">' + fmt(bs.sell) + '</td>' +
                       '<td class="text-end">' + fmt(sb.sell) + '</td>' +
                       '</tr>' +
                       '<tr><td class="fw-bold bg-warning">P/L</td>' +
                       '<td class="text-end">' + fmt(same.diff) + '</td>' +
                       '<td class="text-end">' + fmt(bs.diff) + '</td>' +
                       '<td class="text-end">' + fmt(sb.diff) + '</td>' +
                       '</tr>' +
                       '<tr><td class="fw-bold bg-warning">%</td>' +
                       '<td class="text-end">' + fmtPct(same.pct) + '</td>' +
                       '<td class="text-end">' + fmtPct(bs.pct) + '</td>' +
                       '<td class="text-end">' + fmtPct(sb.pct) + '</td>' +
                       '</tr>' +
                       '</tbody></table></div>';

            $('#dayDiff').html(html);
        });

        // on initial load, if no group selected, show recent trades (last 5 days)
        if ($('.group-checkbox:checked').length === 0) {
            $.get('/StockTrade/GetRecentTrades?days=5', function(html) {
                $('#tradeTable').html(html);
            });
        }
    });
</script>