@model IEnumerable<ZerodaTrade.Models.StockTradeSummary>

@if (Model == null || !Model.Any())
{
    <div style="width:100%; max-height:60vh; overflow-y:auto;">
        <div>No trades found for this instrument.</div>
    </div>
}
else
{
    <div style="max-height:700px; overflow-y:auto;">
        <table class="stylish-table">
            <thead>
                <tr>
                    <th rowspan="2" style="width:110px; text-align:left;">Date</th>
                    <th rowspan="2" class="wrap" style="width:150px; text-align:left;">Instrument</th>
                    <th colspan="3" class="buy">BUY</th>
                    <th colspan="3" class="sell">SELL</th>
                </tr>
                <tr class="sub-header">
                    <th class="no-trim" style="width:60px;">Qty</th>
                    <th class="no-trim" style="width:100px;">Avg</th>
                    <th class="no-trim" style="width:120px;">Total</th>
                    <th class="no-trim" style="width:60px;">Qty</th>
                    <th class="no-trim" style="width:100px;">Avg</th>
                    <th class="no-trim" style="width:120px;">Total</th>
                </tr>
            </thead>
            <tbody>
            @{ 
                // compute both local and UTC date values to tolerate DateTime Kind differences
                DateTime serverToday = DateTime.Now.Date;
                DateTime serverYesterday = serverToday.AddDays(-1);
                DateTime utcToday = DateTime.UtcNow.Date;
                DateTime utcYesterday = utcToday.AddDays(-1);
                DateTime? lastDate = null; 
            }
            @foreach(var r in Model)
            {
                var showDate = !lastDate.HasValue || lastDate.Value != r.Date;
                // Highlight rows for today/yesterday (match either server local or UTC date)
                var rowClass = (r.Date.Date == serverToday || r.Date.Date == utcToday) ? "table-info"
                               : (r.Date.Date == serverYesterday || r.Date.Date == utcYesterday) ? "table-warning"
                               : "";
                // highlight the date cell when the trade date is within the last 3 days (including today)
                var isRecent = (r.Date.Date >= serverToday.AddDays(-3) && r.Date.Date <= serverToday)
                               || (r.Date.Date >= utcToday.AddDays(-3) && r.Date.Date <= utcToday);
                var dateCellClass = isRecent ? "recent-date" : string.Empty;
                <tr class="summary-row @rowClass" data-date="@r.Date.ToString("yyyy-MM-dd")" data-instrument="@r.Instrument" style="cursor:pointer;">
                    <td class="text-start @dateCellClass">@(showDate ? r.Date.ToString("yyyy-MM-dd") : string.Empty)</td>
                    <td class="text-start">@r.Instrument</td>
                    <td class="no-trim">@(r.BuyQty == 0 ? string.Empty : r.BuyQty.ToString())</td>
                    <td class="no-trim">@(r.BuyAverage == 0m ? string.Empty : String.Format(System.Globalization.CultureInfo.InvariantCulture, "{0:N1}", r.BuyAverage))</td>
                    <td class="no-trim">@(r.BuyTotal == 0m ? string.Empty : String.Format(System.Globalization.CultureInfo.InvariantCulture, "{0:N}", r.BuyTotal))</td>
                    <td class="no-trim">@(r.SellQty == 0 ? string.Empty : r.SellQty.ToString())</td>
                    <td class="no-trim">@(r.SellAverage == 0m ? string.Empty : String.Format(System.Globalization.CultureInfo.InvariantCulture, "{0:N1}", r.SellAverage))</td>
                    <td class="no-trim">@(r.SellTotal == 0m ? string.Empty : String.Format(System.Globalization.CultureInfo.InvariantCulture, "{0:N0}", r.SellTotal))</td>
                </tr>
                lastDate = r.Date;
            }
            </tbody>
        </table>
    </div>
}
