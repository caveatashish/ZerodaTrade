@model IEnumerable<ZerodaTrade.Models.StockTradeSummary>

@if (Model == null || !Model.Any())
{
    <div style="width:100%; max-height:60vh; overflow-y:auto;">
        <div>No trades found for this instrument.</div>
    </div>
}
else
{
    <div style="max-height:700px; overflow-y:auto;">
        <table class="stylish-table">
            <thead>
                <tr>
                    <th rowspan="2" style="width:120px;">Date</th>
                    <th rowspan="2" class="wrap" style="width:120px;">Instrument</th>
                    <th colspan="3" class="buy">BUY</th>
                    <th colspan="3" class="sell">SELL</th>
                </tr>
                <tr class="sub-header">
                    <th class="no-trim" style="width:80px;">Qty</th>
                    <th class="no-trim" style="width:100px;">Avg</th>
                    <th class="no-trim" style="width:100px;">Total</th>
                    <th class="no-trim" style="width:80px;">Qty</th>
                    <th class="no-trim" style="width:100px;">Avg</th>
                    <th class="no-trim" style="width:100px;">Total</th>
                </tr>
            </thead>
            <tbody>

        <tbody>
            @{ DateTime? lastDate = null; }
            @foreach(var r in Model)
            {
                var showDate = !lastDate.HasValue || lastDate.Value != r.Date;
                <tr class="summary-row" data-date="@r.Date.ToString("yyyy-MM-dd")" data-instrument="@r.Instrument" style="cursor:pointer;">
                    <td>@(showDate ? r.Date.ToString("yyyy-MM-dd") : string.Empty)</td>
                    <td>@r.Instrument</td>
                    <td class="no-trim">@(r.BuyQty == 0 ? string.Empty : r.BuyQty.ToString())</td>
                    <td class="no-trim">@(r.BuyAverage == 0m ? string.Empty : String.Format(System.Globalization.CultureInfo.InvariantCulture, "{0:N0}", r.BuyAverage))</td>
                    <td class="no-trim">@(r.BuyTotal == 0m ? string.Empty : String.Format(System.Globalization.CultureInfo.InvariantCulture, "{0:N0}", r.BuyTotal))</td>
                    <td class="no-trim">@(r.SellQty == 0 ? string.Empty : r.SellQty.ToString())</td>
                    <td class="no-trim">@(r.SellAverage == 0m ? string.Empty : String.Format(System.Globalization.CultureInfo.InvariantCulture, "{0:N0}", r.SellAverage))</td>
                    <td class="no-trim">@(r.SellTotal == 0m ? string.Empty : String.Format(System.Globalization.CultureInfo.InvariantCulture, "{0:N0}", r.SellTotal))</td>
                </tr>
                lastDate = r.Date;
            }
        </tbody>
        </table>
    </div>
}
