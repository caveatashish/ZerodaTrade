@model ZerodaTrade.Models.Trade

@{
    ViewData["Title"] = "Edit Trade";
}

<div class="container mt-3">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0">@ViewData["Title"]</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <input type="hidden" asp-for="Id" />

                        <div class="mb-3">
                            <label asp-for="FillTime" class="form-label"></label>
                            <input asp-for="FillTime" class="form-control" type="datetime-local" value="@(Model.FillTime.ToString("yyyy-MM-ddTHH:mm"))" />
                            <span asp-validation-for="FillTime" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Type" class="form-label"></label>
                            <select asp-for="Type" class="form-select">
                                <option value="buy" selected="@(Model.Type == "buy" ? "selected" : null)">Buy</option>
                                <option value="sell" selected="@(Model.Type == "sell" ? "selected" : null)">Sell</option>
                            </select>
                            <span asp-validation-for="Type" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Instrument" class="form-label"></label>
                            <input asp-for="Instrument" class="form-control" />
                            <span asp-validation-for="Instrument" class="text-danger"></span>
                        </div>

                        <div class="form-check mb-3">
                            <input type="hidden" name="CNC" value="false" />
                            <input class="form-check-input" type="checkbox" id="CNC" name="CNC" value="true" @(Model.CNC == true ? "checked" : null) />
                            <label class="form-check-label" for="CNC">CNC</label>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Qty" class="form-label"></label>
                            <input asp-for="Qty" class="form-control" type="number" min="1" />
                            <span asp-validation-for="Qty" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="AvgPrice" class="form-label"></label>
                            <input asp-for="AvgPrice" class="form-control" type="number" step="0.01" />
                            <span asp-validation-for="AvgPrice" class="text-danger"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-warning">Save</button>
                            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
