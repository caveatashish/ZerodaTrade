@model ZerodaTrade.Models.Watchlist

@{
    ViewData["Title"] = "Watchlist Entry Details";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-info text-white">
                    <h4 class="mb-0">@ViewData["Title"]</h4>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <h6 class="text-muted">Script Name</h6>
                            <p class="fs-5"><strong>@Model.ScriptName</strong></p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted">Group Name</h6>
                            <p class="fs-5"><strong>@Model.GroupName</strong></p>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-12">
                            <h6 class="text-muted">Description</h6>
                            <p>
                                @if (!string.IsNullOrEmpty(Model.Description))
                                {
                                    <span>@Model.Description</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </p>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <h6 class="text-muted">Current Price</h6>
                            <p class="fs-5">
                                @if (Model.Price.HasValue)
                                {
                                    <strong>? @Model.Price.Value.ToString("F2")</strong>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted">Status</h6>
                            <p class="fs-5">
                                @if (!string.IsNullOrEmpty(Model.Status))
                                {
                                    <span class="badge bg-primary">@Model.Status</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </p>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <h6 class="text-muted">Created Date</h6>
                            <p>@Model.CreatedDate.ToString("dd MMM yyyy hh:mm tt")</p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted">Last Modified</h6>
                            <p>@Model.ModifiedDate.ToString("dd MMM yyyy hh:mm tt")</p>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                            <i class="bi bi-pencil-square"></i> Edit
                        </a>
                        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
                            <i class="bi bi-trash"></i> Delete
                        </a>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-list"></i> Back to List
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
